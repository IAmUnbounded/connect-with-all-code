# WhatsApp (Baileys — WhatsApp Web protocol)
# Auth sessions are saved to ./auth_store/ automatically.
# Just scan the QR code on first run — no API keys needed!
# AUTH_STORE_PATH=./auth_store

# Allowlist: comma-separated phone numbers (digits only, no + or spaces) that
# are permitted to interact with the gateway. All other numbers are silently
# ignored. Leave unset (or empty) to allow all numbers (not recommended for
# production).
# ALLOWLIST_NUMBERS=15551234567,447911123456

# Redis (optional — uses in-memory fallback by default)
# REDIS_URL=redis://localhost:6379

# Server
PORT=3000
